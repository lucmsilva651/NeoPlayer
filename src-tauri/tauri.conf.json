{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "neoplayer",
  "version": "2.0.0",
  "identifier": "com.lucmsilva.neoplayer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NeoPlayer",
        "decorations": false,
        "maximizable": false,
        "resizable": false,
        "width": 925,
        "height": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/icons/32x32.png",
      "../src/icons/64x64.png",
      "../src/icons/128x128.png",
      "../src/icons/128x128@2x.png",
      "../src/icons/icon.icns",
      "../src/icons/icon.ico",
      "../src/icons/icon.png",
      "../src/icons/Square30x30Logo.png",
      "../src/icons/Square44x44Logo.png",
      "../src/icons/Square71x71Logo.png",
      "../src/icons/Square89x89Logo.png",
      "../src/icons/Square107x107Logo.png",
      "../src/icons/Square142x142Logo.png",
      "../src/icons/Square150x150Logo.png",
      "../src/icons/Square284x284Logo.png",
      "../src/icons/Square310x310Logo.png",
      "../src/icons/StoreLogo.png"
    ],
    "category": "Music",
    "linux": {
      "deb": {
        "priority": "optional"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}